# Copy to .env.local for local development (npm start on develop).
# Uses test Excel repo — safe for destructive testing.
#
# One-time setup:
#   npm run setup:dev-data
#
# Or copy this file manually:
#   copy env.local.example .env.local

GITHUB_TOKEN=
GITHUB_OWNER=egorchatov-jpg
GITHUB_DATA_REPO=proverki-kb-data-dev

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:egorchatov@gmail.com

PORT=3000
HOST=0.0.0.0
ENABLE_BACKUP_CRON=0
