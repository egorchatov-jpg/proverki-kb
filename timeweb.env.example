# Copy these variables into Timeweb Cloud App Platform -> Environment
# GitHub data repo (proverki-kb-data)
GITHUB_TOKEN=
GITHUB_OWNER=egorchatov-jpg
GITHUB_DATA_REPO=proverki-kb-data

# Web Push (VAPID) — same keys as in index.html and Vercel
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:egorchatov@gmail.com

# Server (Timeweb usually sets PORT automatically)
PORT=3000
HOST=0.0.0.0
ENABLE_BACKUP_CRON=1
